<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f4f6f9;
        }

        /* Navbar */
        .navbar {
            background: #333;
            color: white;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .navbar h1 {
            margin: 0;
            font-size: 20px;
        }

        .logout {
            background: #ff4d4d;
            border: none;
            padding: 8px 15px;
            color: white;
            border-radius: 5px;
            cursor: pointer;
            text-decoration: none;
        }

        .logout:hover {
            opacity: 0.9;
        }

        /* Container */
        .container {
            display: flex;
            justify-content: center;
            align-items: center;
            height: calc(100vh - 70px);
        }

        /* Card */
        .card {
            background: white;
            padding: 30px;
            border-radius: 12px;
            text-align: center;
            width: 320px;
            box-shadow: 0 6px 25px rgba(0,0,0,0.1);
        }

        .card img {
            width: 110px;
            height: 110px;
            object-fit: cover;
            border-radius: 50%;
            margin-bottom: 15px;
            border: 3px solid #4CAF50;
        }

        .card h2 {
            margin: 10px 0;
            color: #333;
        }

        .card p {
            color: #777;
            font-size: 14px;
            margin: 5px 0;
        }

        .badge {
            background: #4CAF50;
            color: white;
            padding: 5px 12px;
            border-radius: 5px;
            font-size: 12px;
            display: inline-block;
            margin-top: 10px;
        }

        .upload-btn {
            display: inline-block;
            margin-bottom: 5px;
            padding: 5px 15px;
            background: #4CAF50;
            color: white;
            border-radius: 5px;
            text-decoration: none;
        }

        .upload-btn:hover {
            opacity: 0.9;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <div class="navbar">
        <h1>My Dashboard</h1>
        <div>
            <a href="/api/profile/editPassword" class="logout">config</a>
        <a href="/api/auth/logout" class="logout">Logout</a> 
    

        
        </div>
    </div>

    <!-- Main -->
    <div class="container">
        <div class="card">

            <!-- Image -->
            <img src="<%= user?.image || '/default-avatar.png' %>" alt="User Image"><br>

            <!-- Upload -->
            <a href="/api/profile/upload" class="upload-btn">Edit Profile</a>

            <!-- Info -->
            <h2><%= user?.username || "Unknown User" %></h2>
            <p><%= user?.email || "No Email" %></p>

            <!-- Role -->
            <div class="badge">
                <%= user?.isAdmin ? "Admin" : "User" %>
            </div>

        </div>
    </div>

</body>
</html>