<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Password Changed</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f4f6f9;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .container {
            background: #fff;
            padding: 40px;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            max-width: 400px;
            width: 100%;
        }

        .icon {
            font-size: 60px;
            color: #28a745;
        }

        h1 {
            margin: 20px 0 10px;
            font-size: 24px;
            color: #333;
        }

        p {
            color: #666;
            font-size: 14px;
        }

        a {
            display: inline-block;
            margin-top: 25px;
            padding: 10px 20px;
            background: #007bff;
            color: #fff;
            text-decoration: none;
            border-radius: 5px;
            transition: 0.3s;
        }

        a:hover {
            background: #0056b3;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="icon">✔️</div>

        <h1>Password Changed</h1>
        <p>Your password has been successfully updated.</p>

        <a href="/login">Back to Login</a>
    </div>

</body>
</html>