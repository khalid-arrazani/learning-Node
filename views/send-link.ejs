<!-- views/check-email.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Check Your Email</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        body {
            background-color: #f0f2f5;
            height: 100vh;
        }

        .card-custom {
            max-width: 450px;
            text-align: center;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }

        h3 {
            color: #333;
            margin-bottom: 20px;
        }

        p {
            font-size: 16px;
            color: #555;
            margin-bottom: 30px;
        }

        .btn-go-login {
            background-color: #4285F4;
            color: white;
            font-weight: 500;
            padding: 10px 20px;
            border-radius: 8px;
            border: none;
            text-decoration: none;
        }

        .btn-go-login:hover {
            background-color: #357ae8;
        }
    </style>
</head>
<body class="d-flex justify-content-center align-items-center">

    <div class="card-custom bg-white">
        <h3>Check Your Email</h3>
        <p>We have sent a password reset link to your email. Please follow the instructions to reset your password.</p>
        <a href="http://localhost:5000/api/auth/login" class="btn-go-login">Go to Login</a>
    </div>

</body>
</html>