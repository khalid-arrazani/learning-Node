<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password</title>
</head>
<body class=" my-5 d-flex justify-content-center align-items-center" style="background-color: rgb(198, 198, 210);">
    <div class="w-50 bg-white p-5 rounded">
        <h3>Forgot Password</h3>
        <form action="" method="post">
        <label class="form-label" for="email">email</label>
        <input class="form-control" type="email" required id="email" name="email">
        <button class="btn btn-success mt-3 " type="submit">Submit</button>
        </form>
    </div>
</body>
</html>