<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Image</title>

    <style>
        body {
            font-family: Arial;
            background: #f4f4f4;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .container {
            background: #fff;
            padding: 30px;
            border-radius: 10px;
            width: 350px;
            text-align: center;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        input {
            margin: 15px 0;
        }

        button {
            padding: 10px 20px;
            background: #4CAF50;
            color: white;
            border: none;
            cursor: pointer;
            border-radius: 5px;
        }

        img {
            margin-top: 20px;
            width: 150px;
            border-radius: 10px;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>Upload Image</h2>

    <!-- Upload Form -->
    <form action="/api/profile/upload" method="POST" enctype="multipart/form-data">
        <input type="file" name="image" required>
        <br>
        <button type="submit">Upload</button>
    </form>

    <!-- Show Image -->
    <% if (imageUrl) { %>
        <h3>Uploaded Image:</h3>
        <img src="<%= imageUrl %>" alt="uploaded">
      
    <% } %>

</div>

</body>
</html>